# Ticketmaster Discovery API
# Get your API key at: https://developer.ticketmaster.com/products-and-docs/apis/getting-started/
TICKETMASTER_API_KEY=your_ticketmaster_api_key_here

# Meetup.com OAuth Token
# Set up OAuth at: https://www.meetup.com/api/oauth/authorize
MEETUP_OAUTH_TOKEN=your_meetup_oauth_token_here

# Optional: Database path (not used in Vercel deployment)
DATABASE_PATH=./data/netscope.db
